{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://anvil.dev/schemas/project.schema.json",
  "title": "Project",
  "description": "A logical project (business effort) that references one or more shared repositories. A project is not a repo; two projects may safely reference the same repo.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "project_id",
    "schema_version",
    "name",
    "created_at",
    "repos"
  ],
  "properties": {
    "project_id": {
      "type": "string",
      "pattern": "^proj-[A-Za-z0-9._-]+$"
    },
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "repos": {
      "type": "array",
      "minItems": 1,
      "description": "Identifiers of shared repositories this project references.",
      "items": {
        "type": "string",
        "pattern": "^repo-[A-Za-z0-9._-]+$"
      }
    },
    "task_scopes": {
      "type": "object",
      "description": "Bounded operating areas inside the project's repo, keyed by scope id.",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["root_paths"],
        "properties": {
          "root_paths": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "discovery_focus_paths": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "default_forbidden_changes": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "baseline_commands": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["command_array"],
              "properties": {
                "command_array": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "label": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        }
      }
    }
  }
}
