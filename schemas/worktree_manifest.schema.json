{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://anvil.dev/schemas/worktree_manifest.schema.json",
  "title": "Worktree Manifest",
  "description": "Description of a scoped git worktree allocated for a run.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "schema_version",
    "created_at",
    "worktree_id",
    "base_repo",
    "base_commit",
    "branch",
    "path",
    "status"
  ],
  "properties": {
    "run_id": {
      "type": "string",
      "pattern": "^RUN-[0-9]{8}-[0-9]{3,}$"
    },
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "worktree_id": {
      "type": "string",
      "minLength": 1
    },
    "base_repo": {
      "type": "string",
      "minLength": 1
    },
    "base_commit": {
      "type": "string",
      "pattern": "^[0-9a-f]{7,40}$"
    },
    "branch": {
      "type": "string",
      "minLength": 1
    },
    "path": {
      "type": "string",
      "minLength": 1
    },
    "file_scope": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "status": {
      "type": "string",
      "enum": ["active", "merged", "discarded"]
    },
    "work_order_id": {
      "type": "string",
      "pattern": "^EXEC-(INT-)?[0-9]{3,}$"
    },
    "execution_status": {
      "type": "string",
      "enum": [
        "pending",
        "success",
        "lease_conflict",
        "scope_violation",
        "secret_detected",
        "validation_failed",
        "rollback_error"
      ]
    },
    "touched_files": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "validation_status": {
      "type": "string",
      "enum": ["passed", "failed", "pending"]
    },
    "rollback_status": {
      "type": "string",
      "enum": ["success", "failed", "not_needed"]
    },
    "file_ownership": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["file_path", "owners"],
        "properties": {
          "file_path": { "type": "string", "minLength": 1 },
          "owners": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["work_order_id", "access", "sequence"],
              "properties": {
                "work_order_id": { "type": "string", "minLength": 1 },
                "access": { "type": "string", "enum": ["read", "write"] },
                "sequence": { "type": "integer", "minimum": 1 }
              }
            }
          }
        }
      }
    }
  }
}
