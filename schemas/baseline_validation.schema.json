{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://anvil.dev/schemas/baseline_validation.schema.json",
  "title": "Baseline Validation",
  "description": "Validation state of the base commit before any changes are made. Commands are structured argv arrays.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "schema_version",
    "captured_at",
    "base_commit",
    "baseline_green",
    "commands"
  ],
  "properties": {
    "run_id": {
      "type": "string",
      "pattern": "^RUN-[0-9]{8}-[0-9]{3,}$"
    },
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "captured_at": {
      "type": "string",
      "format": "date-time"
    },
    "base_commit": {
      "type": "string",
      "pattern": "^[0-9a-f]{7,40}$"
    },
    "baseline_green": {
      "type": "boolean",
      "description": "True when all baseline commands passed."
    },
    "commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["command_array", "exit_code", "passed"],
        "properties": {
          "command_array": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "exit_code": {
            "type": "integer"
          },
          "passed": {
            "type": "boolean"
          }
        }
      }
    }
  }
}
