{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://anvil.dev/schemas/human_decision.schema.json",
  "title": "Human Decision",
  "description": "A decision made by a human during escalation. Milestone 2: supports multiple issue_ids, scope_delta, tamper-detectable content_hash, and controller_observed_at.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "decision_id",
    "run_id",
    "issue_ids",
    "decision",
    "rationale",
    "approved_by",
    "created_at",
    "content_hash"
  ],
  "properties": {
    "decision_id": {
      "type": "string",
      "pattern": "^DEC-[0-9]{3,}$"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "issue_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^ISSUE-[0-9]{3,}$"
      },
      "minItems": 1
    },
    "decision": {
      "type": "string",
      "enum": ["approve", "reject", "defer", "modify_scope"]
    },
    "rationale": {
      "type": "string",
      "minLength": 1
    },
    "scope_delta": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "goals_added": {"type": "array", "items": {"type": "string"}},
        "goals_removed": {"type": "array", "items": {"type": "string"}},
        "non_goals_added": {"type": "array", "items": {"type": "string"}},
        "forbidden_changes_relaxed": {"type": "array", "items": {"type": "string"}},
        "constraints_added": {"type": "array", "items": {"type": "string"}}
      }
    },
    "approved_by": {
      "type": "string",
      "minLength": 1
    },
    "expires_after_run": {
      "type": "boolean"
    },
    "requires_contract_amendment": {
      "type": "boolean"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "controller_observed_at": {
      "type": "string",
      "format": "date-time"
    },
    "content_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    }
  }
}
