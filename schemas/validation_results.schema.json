{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://anvil.dev/schemas/validation_results.schema.json",
  "title": "Validation Results",
  "description": "Results of running a work order's structured validation commands, diffed against baseline. Extended in Milestone 5 with per-work-order and integration results.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "schema_version",
    "generated_at",
    "work_order_ref",
    "overall_passed",
    "results"
  ],
  "properties": {
    "run_id": {
      "type": "string",
      "pattern": "^RUN-[0-9]{8}-[0-9]{3,}$"
    },
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "work_order_ref": {
      "type": "string",
      "pattern": "^EXEC-(INT-)?[0-9]{3,}$"
    },
    "overall_passed": {
      "type": "boolean"
    },
    "new_failures_vs_baseline": {
      "type": "integer",
      "minimum": 0
    },
    "results": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["command_array", "exit_code", "passed"],
        "properties": {
          "command_array": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "exit_code": {
            "type": "integer"
          },
          "passed": {
            "type": "boolean"
          },
          "stdout_excerpt": {
            "type": "string"
          },
          "stderr_excerpt": {
            "type": "string"
          },
          "started_at": {
            "type": "string",
            "format": "date-time"
          },
          "finished_at": {
            "type": "string",
            "format": "date-time"
          },
          "duration_seconds": {
            "type": "number",
            "minimum": 0
          },
          "timed_out": {
            "type": "boolean"
          },
          "policy_allowed": {
            "type": "boolean"
          }
        }
      }
    },
    "work_order_results": {
      "type": "array",
      "description": "Milestone 5: per-work-order execution and merge status summary.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["work_order_id", "execution_status"],
        "properties": {
          "work_order_id": {
            "type": "string",
            "pattern": "^EXEC-(INT-)?[0-9]{3,}$"
          },
          "execution_status": {
            "type": "string"
          },
          "merge_status": {
            "type": "string"
          },
          "validation_passed": {
            "type": "boolean"
          },
          "new_failures": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    },
    "integration_result": {
      "type": "object",
      "description": "Milestone 5: summary of the integration work order result.",
      "additionalProperties": false,
      "properties": {
        "work_order_id": {
          "type": "string",
          "pattern": "^EXEC-(INT-)?[0-9]{3,}$"
        },
        "overall_passed": {
          "type": "boolean"
        },
        "new_failures_vs_baseline": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "command_policy_status": {
      "type": "string",
      "description": "Milestone 5: overall command policy compliance status.",
      "enum": ["all_allowed", "some_blocked", "unknown"]
    },
    "timeout_status": {
      "type": "string",
      "description": "Milestone 5: whether any command timed out.",
      "enum": ["no_timeouts", "some_timed_out", "unknown"]
    }
  }
}
