{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://anvil.dev/schemas/risk_assessment.schema.json",
  "title": "Risk Assessment",
  "description": "Numeric, staged risk scoring with mode escalation. Implements the implementation-spec 2.3 contract.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "assessments"
  ],
  "properties": {
    "run_id": {
      "type": "string",
      "pattern": "^RUN-[0-9]{8}-[0-9]{3,}$"
    },
    "current_mode": {
      "type": "string",
      "enum": ["fast", "standard", "critical"]
    },
    "current_score": {
      "type": "integer"
    },
    "assessments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["stage", "score", "factors", "mode", "timestamp"],
        "properties": {
          "stage": {
            "type": "string",
            "enum": ["initial", "post_discovery", "post_plan", "post_execution"]
          },
          "score": {
            "type": "integer"
          },
          "factors": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["factor", "value", "reason"],
              "properties": {
                "factor": {
                  "type": "string",
                  "minLength": 1
                },
                "value": {
                  "type": "integer"
                },
                "reason": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          },
          "mode": {
            "type": "string",
            "enum": ["fast", "standard", "critical"]
          },
          "mode_changed": {
            "type": "boolean"
          },
          "escalation_reason": {
            "type": "string"
          },
          "assessed_by": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  }
}
